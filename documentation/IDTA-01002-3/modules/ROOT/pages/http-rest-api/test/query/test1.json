{
    "$schema": "../../query-json-schema.json",
    "select": "id",
    "$filters": [
        {
            "$fragment": "$sme#value",
            "$condition": {
                "$eq": [
                    {
                        "$field": "$sm#semanticId.keys[].value"
                    },
                    {
                        "$strVal": "https://example.org/value"
                    }
                ]
            }
        }
    ],
    "option": {
        "sort": {
            "id": "asc"
        },
        "limit": 10,
        "offset": 0
    }
}